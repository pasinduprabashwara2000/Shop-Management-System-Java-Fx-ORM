<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.ijse.mvc.fx.sms.controller.DashboardController"
            stylesheets="@css/styles.css">

    <ScrollPane styleClass="dashboard-scroll" fitToWidth="true"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox styleClass="dashboard-content" spacing="20">

            <!-- ── Welcome Banner ─────────────────────────── -->
            <HBox styleClass="dashboard-welcome" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="6">
                    <Label styleClass="dashboard-welcome-title" text="Welcome back! 👋" />
                    <Label styleClass="dashboard-welcome-subtitle" text="Here's what's happening in your shop today." />
                </VBox>
                <Pane HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="4">
                    <Label fx:id="lblDate" styleClass="dashboard-welcome-subtitle" text="Saturday, 28 Feb 2026" />
                    <Label fx:id="lblTime" styleClass="dashboard-welcome-subtitle" text="12:00 PM" />
                </VBox>
            </HBox>

            <!-- ── Stat Cards ──────────────────────────────── -->
            <HBox spacing="16">

                <!-- Total Customers -->
                <VBox styleClass="stat-card,stat-card-blue" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="👤" styleClass="stat-card-icon" />
                    <Label fx:id="lblTotalCustomers" text="0" styleClass="stat-card-value,stat-card-value-blue" />
                    <Label text="TOTAL CUSTOMERS" styleClass="stat-card-label" />
                </VBox>

                <!-- Total Products -->
                <VBox styleClass="stat-card,stat-card-green" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="📦" styleClass="stat-card-icon" />
                    <Label fx:id="lblTotalProducts" text="0" styleClass="stat-card-value,stat-card-value-green" />
                    <Label text="TOTAL PRODUCTS" styleClass="stat-card-label" />
                </VBox>

                <!-- Today's Orders -->
                <VBox styleClass="stat-card,stat-card-orange" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="🧾" styleClass="stat-card-icon" />
                    <Label fx:id="lblTodayOrders" text="0" styleClass="stat-card-value,stat-card-value-orange" />
                    <Label text="TODAY'S ORDERS" styleClass="stat-card-label" />
                </VBox>

                <!-- Total Revenue -->
                <VBox styleClass="stat-card,stat-card-red" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="💰" styleClass="stat-card-icon" />
                    <Label fx:id="lblTotalRevenue" text="Rs. 0.00" styleClass="stat-card-value,stat-card-value-red" />
                    <Label text="TOTAL REVENUE" styleClass="stat-card-label" />
                </VBox>

            </HBox>

            <!-- ── Bottom Row: Recent Orders + Quick Actions ── -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <!-- Recent Orders Table -->
                <VBox styleClass="dashboard-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Recent Orders" styleClass="dashboard-section-title" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button text="View All →" onAction="#btnViewAllOrdersOnAction"
                                styleClass="btn,btn-primary"
                                style="-fx-padding: 5 14; -fx-font-size: 12px;" />
                    </HBox>

                    <TableView fx:id="tblRecentOrders" prefHeight="280" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colOrderId"       text="Order ID"   prefWidth="80"  />
                            <TableColumn fx:id="colOrderCustomer" text="Customer"   prefWidth="160" />
                            <TableColumn fx:id="colOrderDate"     text="Date"       prefWidth="110" />
                            <TableColumn fx:id="colOrderTotal"    text="Total"      prefWidth="100" />
                            <TableColumn fx:id="colOrderStatus"   text="Status"     prefWidth="90"  />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- Quick Actions + Low Stock -->
                <VBox spacing="16" prefWidth="240">

                    <!-- Quick Actions -->
                    <VBox styleClass="dashboard-card" spacing="12">
                        <Label text="Quick Actions" styleClass="dashboard-section-title" />
                        <Button text="➕  New Order"    maxWidth="Infinity" onAction="#btnNewOrderOnAction"    styleClass="quick-action-btn" />
                        <Button text="👤  Add Customer" maxWidth="Infinity" onAction="#btnAddCustomerOnAction" styleClass="quick-action-btn" />
                        <Button text="📦  Add Product"  maxWidth="Infinity" onAction="#btnAddProductOnAction"  styleClass="quick-action-btn" />
                        <Button text="📊  View Reports" maxWidth="Infinity" onAction="#btnViewReportsOnAction" styleClass="quick-action-btn" />
                    </VBox>

                    <!-- Low Stock Alert -->
                    <VBox styleClass="dashboard-card" spacing="12" VBox.vgrow="ALWAYS">
                        <Label text="⚠️  Low Stock Alerts" styleClass="dashboard-section-title" />
                        <TableView fx:id="tblLowStock" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colLowStockName" text="Product" prefWidth="140" />
                                <TableColumn fx:id="colLowStockQty"  text="Qty"    prefWidth="60"  />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                </VBox>

            </HBox>

        </VBox>
    </ScrollPane>

</AnchorPane>
