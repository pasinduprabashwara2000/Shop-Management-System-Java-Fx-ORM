<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.ijse.mvc.fx.sms.controller.OrderController"
            prefWidth="1000" prefHeight="700"
            styleClass="app-root"
            stylesheets="@css/styles.css">

    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" spacing="0">

        <!-- Header -->
        <HBox styleClass="section-header" alignment="CENTER_LEFT">
            <Label text="Order Management" styleClass="section-header-title"/>
        </HBox>

        <!-- Order Info Card -->
        <VBox styleClass="form-card" spacing="16">
            <Label text="Order Details" styleClass="form-section-label"/>

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="120" prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Order ID:"      styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="txtOrderId" styleClass="text-field,field-readonly"
                           promptText="Auto-generated" editable="false"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Date:"    styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <DatePicker fx:id="dpDate" styleClass="date-picker" maxWidth="Infinity"
                            GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="Customer:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="cmbCustomerId" styleClass="combo-box"
                          promptText="Select Customer" maxWidth="Infinity"
                          onAction="#cmbCustomerIdOnAction"
                          GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Customer Name:" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="txtCustomerName" styleClass="text-field,field-readonly"
                           editable="false"
                           GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            </GridPane>
        </VBox>

        <!-- Add Product Row -->
        <HBox styleClass="search-bar" alignment="CENTER_LEFT" spacing="14">
            <Label text="Product:"   styleClass="field-label"/>
            <ComboBox fx:id="cmbProductId" styleClass="combo-box"
                      promptText="Select Product"
                      onAction="#cmbProductIdOnAction" prefWidth="180"/>

            <Label text="Price:"    styleClass="field-label"/>
            <TextField fx:id="txtPrice" styleClass="text-field,field-readonly"
                       promptText="0.00" prefWidth="100" editable="false"/>

            <Label text="Qty:"      styleClass="field-label"/>
            <TextField fx:id="txtQty" styleClass="text-field"
                       promptText="1" prefWidth="80"/>

            <Button fx:id="btnAddItem"    text="Add Item" onAction="#btnAddItemOnAction"    styleClass="btn,btn-primary"/>
            <Button fx:id="btnRemoveItem" text="Remove"   onAction="#btnRemoveItemOnAction" styleClass="btn,btn-danger"/>
        </HBox>

        <!-- Order Items Table -->
        <TableView fx:id="tblOrderItems" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colItemId"    text="Item ID"    prefWidth="80"/>
                <TableColumn fx:id="colProductId" text="Product ID" prefWidth="100"/>
                <TableColumn fx:id="colPrice"     text="Unit Price" prefWidth="120"/>
                <TableColumn fx:id="colQty"       text="Quantity"   prefWidth="100"/>
                <TableColumn fx:id="colSubTotal"  text="Sub Total"  prefWidth="120"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <!-- Footer: Total + Actions -->
        <HBox styleClass="footer-bar" alignment="CENTER_RIGHT" spacing="20">
            <Label text="Total:"  styleClass="total-label-key"/>
            <Label fx:id="lblTotal" text="Rs. 0.00" styleClass="total-label-value"/>

            <HBox spacing="10">
                <Button fx:id="btnPlaceOrder" text="Place Order" onAction="#btnPlaceOrderOnAction" styleClass="btn,btn-success,btn-lg"/>
                <Button fx:id="btnClear"      text="Clear"       onAction="#btnClearOnAction"      styleClass="btn,btn-secondary,btn-lg"/>
            </HBox>
        </HBox>

    </VBox>
</AnchorPane>
